// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/////////////////////////
// Models for City Bingo
/////////////////////////

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  role        Role         @default(STUDENT)
  createdAt   DateTime     @default(now())
  submissions Submission[]
  challenges  BingoChallenge[] @relation("CreatedChallenges")
}

model BingoChallenge {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  latitude    Float
  longitude   Float
  createdBy   User         @relation("CreatedChallenges", fields: [createdById], references: [id])
  createdById Int
  createdAt   DateTime     @default(now())
  submissions Submission[]
}

model Submission {
  id          Int              @id @default(autoincrement())
  challenge   BingoChallenge   @relation(fields: [challengeId], references: [id])
  challengeId Int
  user        User             @relation(fields: [userId], references: [id])
  userId      Int
  answer      String
  status      SubmissionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
}

/////////////////////////
// Enums
/////////////////////////

enum Role {
  STUDENT
  TEACHER
}

enum SubmissionStatus {
  PENDING
  APPROVED
  DENIED
}
