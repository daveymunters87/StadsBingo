generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/////////////////////////
// Models for StadsBingo
/////////////////////////

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(TEACHER)
  createdAt DateTime @default(now())

  // Teams created by this teacher
  teams Team[] @relation("TeacherTeams")
}

model TeamPlayer {
  id            String @id @default(cuid())
  name          String
  studentNumber String
  teamId        String
  team          Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // Optional: if this player is captain of a team
  captainOf Team? @relation("Captain")

  // Submissions made by this player
  submissions Submission[]
}

model Team {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("TeacherTeams", fields: [createdById], references: [id])

  // One-to-one relation for captain
  captainId String?     @unique
  captain   TeamPlayer? @relation("Captain", fields: [captainId], references: [id])

  // Players in this team
  players     TeamPlayer[]
  submissions Submission[]

  // Assignments assigned to this team
  assignments TeamAssignment[]
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String
  location    String // e.g., "Bij de bibliotheek"
  order       Int // fixed release order
  createdAt   DateTime @default(now())

  submissions Submission[]

  // Teams assigned to this assignment
  teams TeamAssignment[]
}

model TeamAssignment {
  id           String   @id @default(cuid())
  teamId       String
  assignmentId String
  createdAt    DateTime @default(now())

  team       Team       @relation(fields: [teamId], references: [id])
  assignment Assignment @relation(fields: [assignmentId], references: [id])

  @@unique([teamId, assignmentId])
  @@index([teamId])
  @@index([assignmentId])
}

model Submission {
  id           String   @id @default(cuid())
  teamId       String
  assignmentId String
  playerId     String? // optional, for traceability; not for login
  answerText   String?
  answerImage  String?
  status       Status   @default(PENDING)
  feedback     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  team       Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignment Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  player     TeamPlayer? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@unique([teamId, assignmentId])
  @@index([status])
}

/////////////////////////
// Enums
/////////////////////////

enum Role {
  STUDENT
  TEACHER
}

enum Status {
  LOCKED // Not yet available
  AVAILABLE // Can be completed
  PENDING // Waiting for review
  FEEDBACK // Rejected / feedback provided
  APPROVED // Approved by teacher
}
