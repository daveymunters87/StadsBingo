generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/////////////////////////
// Models for StadsBingo
/////////////////////////

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(TEACHER)
  createdAt DateTime @default(now())

  teams     Team[]   @relation("TeacherTeams")
}

model TeamPlayer {
  id            String   @id @default(cuid())
  name          String
  studentNumber String
  teamId        String
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // inverse side of the captain relation (one-to-one)
  captainOf     Team?    @relation("Captain")

  // inverse side of Submission relation
  submissions   Submission[]
}

model Team {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  createdAt   DateTime      @default(now())
  createdById String
  createdBy   User          @relation("TeacherTeams", fields: [createdById], references: [id])

  // One-to-one relation: each team has at most one captain
  captainId   String?       @unique
  captain     TeamPlayer?   @relation("Captain", fields: [captainId], references: [id])

  players     TeamPlayer[]
  submissions Submission[]
}

model Assignment {
  id          String       @id @default(cuid())
  title       String
  description String
  location    String       // e.g., "Bij de bibliotheek"
  order       Int          // fixed release order
  createdAt   DateTime     @default(now())

  submissions Submission[]
}

model Submission {
  id           String      @id @default(cuid())
  teamId       String
  assignmentId String
  playerId     String?     // optional, for traceability; not for login
  answerText   String?
  answerImage  String?
  status       Status      @default(PENDING)
  feedback     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  team       Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignment Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  player     TeamPlayer?  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@unique([teamId, assignmentId]) // one submission per team per assignment
  @@index([status])
}

/////////////////////////
// Enums
/////////////////////////

enum Role {
  STUDENT
  TEACHER
}

enum Status {
  LOCKED      // Not yet available
  AVAILABLE   // Can be completed
  PENDING     // Waiting for review
  FEEDBACK    // Rejected / feedback provided
  APPROVED    // Approved by teacher
}
