generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Models

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  teams Team[] @relation("TeacherTeams")
}

model TeamPlayer {
  id            String @id @default(cuid())
  name          String
  studentNumber String
  teamId        String
  team          Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  captainOf Team? @relation("Captain")

  submissions Submission[]
}

model Team {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation("TeacherTeams", fields: [createdById], references: [id])

  captainId String?     @unique
  captain   TeamPlayer? @relation("Captain", fields: [captainId], references: [id])

  players     TeamPlayer[]
  submissions Submission[]

  assignments TeamAssignment[]
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String
  location    String 
  order       Int
  createdAt   DateTime @default(now())
  exampleImage String? 

  submissions Submission[]

  teams TeamAssignment[]
}

model TeamAssignment {
  id           String   @id @default(cuid())
  teamId       String
  assignmentId String
  createdAt    DateTime @default(now())

  team       Team       @relation(fields: [teamId], references: [id])
  assignment Assignment @relation(fields: [assignmentId], references: [id])

  @@unique([teamId, assignmentId])
  @@index([teamId])
  @@index([assignmentId])
}

model Submission {
  id           String   @id @default(cuid())
  teamId       String
  assignmentId String
  playerId     String?
  answerImage  String?
  status       Status   @default(PENDING)
  feedback     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  team       Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignment Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  player     TeamPlayer? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@unique([teamId, assignmentId])
  @@index([status])
}

// Enums

enum Role {
  USER
  ADMIN
}

// Status
enum Status {
  LOCKED
  AVAILABLE 
  PENDING
  FEEDBACK 
  APPROVED
}
